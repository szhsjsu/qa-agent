# GLM (智谱 AI) — OpenAI-compatible endpoint
GLM_API_KEY=your_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus
GLM_VERIFY_MODEL=glm-4-air

# Embedding (local BGE — first run downloads ~400MB for bge-small / ~2GB for bge-m3)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Paths
DATA_DIR=./data
INDEX_DIR=./data/index

# Logging
LOG_LEVEL=INFO
